    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@types/ws": "^8.18.1",
    "chalk": "^4.1.2",
    "dotenv": "^16.0.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "speaker": "^0.5.5",
    "ws": "^8.19.0"
